# .env.example — Trading Agent credentials
# Copy this to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# HOW TO USE:
#   1. cp .env.example .env
#   2. Fill in the values below
#   3. docker compose up -d
#
# PORTENER USAGE:
#   In Portainer stack editor, set these as "Environment variables"
#   instead of using a .env file.

# ── Alpaca (paper trading) ────────────────────────────────────────────────────
# Get from: https://app.alpaca.markets/
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── MiniMax LLM (Bull/Bear debate) ───────────────────────────────────────────
# Get from: platform.minimaxi.com → API Keys
MINIMAX_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Secret to verify TradingView webhook calls (optional)
# Set this in TradingView webhook URL: https://your-url.com/webhook/tradingview?secret=YOUR_SECRET
TV_WEBHOOK_SECRET=
